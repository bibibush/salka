# 백엔드 API 루트 URL (예: http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# 웹 CD (S3 + CloudFront) 워크플로가 참조하는 값 [R5-CD1]
# 실제 값은 GitHub Secrets/Variables 로만 주입하며, 아래는 <...> 플레이스홀더로
# "어떤 값이 필요한지"만 문서화한다(로컬 빌드에는 불필요).
# -----------------------------------------------------------------------------
# [Variables]
AWS_REGION=<aws-region>
WEB_S3_BUCKET=<web-static-s3-bucket>
CLOUDFRONT_DISTRIBUTION_ID=<cloudfront-distribution-id>
# [Secrets]
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
