{
  "expo": {
    "name": "cosmetics-analyzer",
    "slug": "cosmetics-analyzer",
    "scheme": "cosmeticsanalyzer",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "전성분 표시면을 촬영해 성분 해석에 사용하기 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "전성분 이미지를 선택해 성분 해석에 사용하기 위해 사진 접근이 필요합니다."
        }
      ]
    ]
  }
}
