# 백엔드 API 베이스 URL. Expo 는 EXPO_PUBLIC_ 접두사 변수만 클라이언트에 노출한다.
# iOS 시뮬레이터는 localhost, Android 에뮬레이터는 10.0.2.2 를 사용한다.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Expo 액세스 토큰 (EAS build/submit/update 인증에 사용). GitHub Actions 에서는
# Secrets.EXPO_TOKEN 으로 참조된다. 실제 값으로 교체할 것.
EXPO_TOKEN=<expo-access-token>
