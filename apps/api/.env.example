# 실행 환경: dev | staging | prod
ENV=dev

# 외부 의존성 provider 선택 (Phase 1 기본값: mock)
# LLM_PROVIDER: mock | openai   /   OCR_PROVIDER: mock | gemini
LLM_PROVIDER=mock
OCR_PROVIDER=mock

# provider별 API 키 (mock 사용 시 불필요, openai/gemini 선택 시 필수)
# 실제 키를 여기에 채워 넣으세요 (아래는 플레이스홀더).
LLM_API_KEY=your-openai-api-key
OCR_API_KEY=your-gemini-api-key

# provider별 모델·튜닝 (env로 재정의 가능)
OPENAI_MODEL=gpt-5.5
GEMINI_MODEL=gemini-3.5-flash
# 추론 강도: minimal | low | medium | high
# OpenAI=reasoning effort, Gemini=thinking level
OPENAI_REASONING_EFFORT=medium
GEMINI_THINKING_LEVEL=low

# CORS 허용 origin (콤마 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# 분당 요청 제한 (Phase 2에서 본격 적용)
RATE_LIMIT_PER_MIN=60

# 업로드 이미지 최대 크기 (바이트). 기본 8MB
MAX_UPLOAD_BYTES=8388608

# 모든 분석 응답에 부착되는 면책 문구
DISCLAIMER_TEXT=본 결과는 공개된 성분 정보를 바탕으로 한 참고용 해석이며, 의학적 진단이나 안전성 보증이 아닙니다. 민감 반응이나 질환이 있는 경우 전문가와 상담하세요.
