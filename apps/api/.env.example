# 이 파일은 로컬/개발(dev) 기본값 템플릿이다. 운영값(ENV=prod, openai/gemini + 키)은
# 레포가 아니라 배포 시 GitHub Secrets/Variables 에서 주입한다(아래 CD 섹션 참고).

# 실행 환경: dev | staging | prod
ENV=dev

# 외부 의존성 provider 선택 (Phase 1 개발 기본값: mock)
# LLM_PROVIDER: mock | openai   /   OCR_PROVIDER: mock | gemini
LLM_PROVIDER=mock
OCR_PROVIDER=mock

# provider별 API 키 (mock 사용 시 불필요, openai/gemini 선택 시 필수)
# 실제 키를 여기에 채워 넣으세요 (아래는 플레이스홀더).
LLM_API_KEY=your-openai-api-key
OCR_API_KEY=your-gemini-api-key

# provider별 모델·튜닝은 env가 아니라 Settings 객체(src/core/config.py)에 고정한다.
# openai_model=gpt-5.5, gemini_model=gemini-3.5-flash
# 추론 강도(minimal | low | medium | high): openai_reasoning_effort=medium, gemini_thinking_level=medium

# CORS 허용 origin (콤마 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# 분당 요청 제한 (Phase 2에서 본격 적용)
RATE_LIMIT_PER_MIN=60

# 업로드 이미지 최대 크기 (바이트). 기본 8MB
MAX_UPLOAD_BYTES=8388608

# 모든 분석 응답에 부착되는 면책 문구
DISCLAIMER_TEXT=본 결과는 공개된 성분 정보를 바탕으로 한 참고용 해석이며, 의학적 진단이나 안전성 보증이 아닙니다. 민감 반응이나 질환이 있는 경우 전문가와 상담하세요.

# -----------------------------------------------------------------------------
# 백엔드 CD (Docker + SSH 자체 서버 배포) 워크플로가 참조하는 값 [R5-CD1]
# 실제 값은 GitHub Secrets/Variables 로만 주입하며, 아래는 <...> 플레이스홀더로
# "어떤 값이 필요한지"만 문서화한다(런타임 실행에는 불필요). 배포 시 이 값들로
# 임시 env-file 을 만들어 컨테이너에 주입한다.
# 공용 nginx(nginx_container)·conf.d·proxy_net·도메인(api.agentops.p-e.kr)·인증서는
# 서버에 고정돼 있어 워크플로가 상수로 처리하므로 별도 변수 등록이 필요 없다.
# -----------------------------------------------------------------------------
# 아래 SSH 값은 app 설정과 이름이 겹치지 않아 활성 플레이스홀더로 둔다(config 는 무시).
# [Secrets]
DEPLOY_SSH_HOST=<deploy-host>
DEPLOY_SSH_USER=<deploy-ssh-user>
DEPLOY_SSH_KEY=<deploy-ssh-private-key-pem>
# [Variables]
DEPLOY_SSH_PORT=<ssh-port>
#
# 아래는 app 설정 키와 이름이 겹치므로 여기서는 "활성 값"이 아니라 주석으로만 문서화한다
# (실제 값은 GitHub 에만 등록 → 배포 시 컨테이너에 주입). 로컬은 위쪽 dev 값을 쓴다.
#   [Secrets]   LLM_API_KEY  운영 LLM(openai) 키 (provider=openai 일 때 필수)
#               OCR_API_KEY  운영 OCR(gemini) 키 (provider=gemini 일 때 필수)
#   [Variables] LLM_PROVIDER 운영 LLM provider (미설정 시 openai)
#               OCR_PROVIDER 운영 OCR provider (미설정 시 gemini)
#               CORS_ORIGINS 운영 CORS 허용 origin (콤마 구분)
